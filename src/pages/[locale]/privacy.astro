---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { LOCALES, getDictionary, isLocale, type Locale } from '@/lib/i18n';
import { getSiteData } from '@/lib/site';
import { getPrivacyPolicy } from '@/lib/privacy';

export const getStaticPaths = async () => LOCALES.map((locale) => ({ params: { locale } }));

const localeParam = Astro.params.locale;
if (!localeParam || !isLocale(localeParam)) {
  return Astro.redirect('/en/privacy');
}

const locale: Locale = localeParam;
const dictionary = getDictionary(locale);
const site = getSiteData(locale);
const currentPath = `/${locale}/privacy`;
const policy = getPrivacyPolicy(locale);
---

<BaseLayout locale={locale} pathname={currentPath} title={dictionary.seo.privacyTitle} description={dictionary.seo.privacyDescription}>
  <Header locale={locale} currentPath={currentPath} dictionary={dictionary} site={site} />
  <main class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <article class="rounded-2xl border border-brand-navy/10 bg-white p-8 shadow-card">
      <h1 class="mb-8 text-3xl font-bold text-brand-navy">{policy.title}</h1>
      <div class="space-y-8 text-sm leading-7 text-brand-graphite/85 sm:text-base">
        {policy.sections.map((section) => (
          <section>
            <h2 class="mb-3 text-xl font-semibold text-brand-navy">{section.number}. {section.title}</h2>
            {section.paragraphs?.map((paragraph) => <p class="mb-3">{paragraph}</p>)}
            {section.bullets && (
              <ul class="mb-3 list-disc space-y-2 ps-5 marker:text-brand-emerald">
                {section.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            )}
            {section.clauses?.map((clause) => (
              <p class="mb-2"><strong>{clause.number}</strong> {clause.text}</p>
            ))}
          </section>
        ))}
      </div>
    </article>
  </main>
  <Footer locale={locale} dictionary={dictionary} />
</BaseLayout>
