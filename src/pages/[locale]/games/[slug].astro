---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import DownloadButtons from '@/components/DownloadButtons.astro';
import ScreenshotGallery from '@/components/ScreenshotGallery.astro';
import FeatureList from '@/components/FeatureList.astro';
import GameCard from '@/components/GameCard.astro';
import { getGameBySlug, getPublishedGameSlugs, getRelatedGames } from '@/lib/games';
import { LOCALES, getDictionary, isLocale, localizePath, type Locale } from '@/lib/i18n';
import { getSiteData } from '@/lib/site';

export const getStaticPaths = async () =>
  LOCALES.flatMap((locale) =>
    getPublishedGameSlugs().map((slug) => ({
      params: { locale, slug }
    }))
  );

const localeParam = Astro.params.locale;
if (!localeParam || !isLocale(localeParam)) return Astro.redirect('/en/');

const locale: Locale = localeParam;
const slug = Astro.params.slug ?? '';
const dictionary = getDictionary(locale);
const site = getSiteData(locale);
const game = getGameBySlug(slug, locale);
if (!game) return Astro.redirect(localizePath(locale));
const relatedGames = getRelatedGames(game.slug, locale);
const currentPath = `/${locale}/games/${game.slug}`;
---

<BaseLayout locale={locale} pathname={currentPath} title={game.seoTitle ?? game.title} description={game.seoDescription ?? game.shortDescription}>
  <Header locale={locale} currentPath={currentPath} dictionary={dictionary} site={site} />
  <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
    <a href={localizePath(locale)} class="mb-7 inline-flex text-sm font-semibold text-brand-emerald hover:text-brand-navy">← {dictionary.game.back}</a>

    <section class="relative overflow-hidden rounded-3xl border border-brand-navy/10 bg-white p-6 shadow-card sm:p-8 lg:p-10">
      <div class="pointer-events-none absolute -right-20 top-0 h-56 w-56 rounded-full bg-brand-gold/15 blur-3xl"></div>
      <div class="pointer-events-none absolute -left-24 bottom-0 h-56 w-56 rounded-full bg-brand-emerald/15 blur-3xl"></div>
      <div class="relative grid items-start gap-8 lg:grid-cols-[140px,1fr] lg:gap-10">
        <div class="mx-auto w-full max-w-[140px] lg:mx-0">
          <img src={game.icon} alt={dictionary.game.iconAlt.replace('{title}', game.title)} class="aspect-square w-full rounded-3xl object-cover shadow-sm" />
        </div>

        <div>
          <h1 class="text-3xl font-bold leading-tight text-brand-navy sm:text-4xl">{game.title}</h1>
          <p class="mt-3 text-base text-brand-graphite/75 sm:text-lg">{game.shortDescription}</p>
          <p class="mt-5 text-brand-graphite/85">{game.description}</p>
          <div class="mt-7 max-w-xl">
            <DownloadButtons downloads={game.downloads} label={dictionary.game.download} emptyLabel={dictionary.game.downloadsSoon} />
          </div>
        </div>
      </div>
    </section>

    <div class="mt-10 space-y-10">
      <ScreenshotGallery
        title={dictionary.game.screenshots}
        hint={dictionary.game.swipeHint}
        screenshots={game.screenshots}
        openLabel={dictionary.game.openScreenshot}
        closeLabel={dictionary.game.closeGallery}
        prevLabel={dictionary.game.previousScreenshot}
        nextLabel={dictionary.game.nextScreenshot}
        captionTemplate={dictionary.game.screenshotOf}
        screenshotAltTemplate={dictionary.game.screenshotAlt}
      />
      <FeatureList features={game.features} title={dictionary.game.featuresTitle} emptyLabel={dictionary.game.featuresSoon} />
      <section>
        <h3 class="mb-4 text-xl font-bold text-brand-navy">{dictionary.game.aboutTitle}</h3>
        <p class="rounded-2xl border border-brand-navy/10 bg-white p-6 text-brand-graphite/85 shadow-card">{game.description}</p>
      </section>
      {relatedGames.length > 0 && (
        <section>
          <h3 class="mb-4 text-xl font-bold text-brand-navy">{dictionary.game.relatedTitle}</h3>
          <div class="grid gap-6 md:grid-cols-2">
            {relatedGames.map((related) => <GameCard locale={locale} game={related} dictionary={dictionary} />)}
          </div>
        </section>
      )}
    </div>
  </main>
  <Footer locale={locale} dictionary={dictionary} />
</BaseLayout>
